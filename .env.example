# ── Base de datos ─────────────────────────────────────────────
# Desarrollo local:
# MONGODB_URL=mongodb://localhost:27017
# Producción (MongoDB Atlas — reemplaza con tu connection string):
MONGODB_URL=mongodb+srv://usuario:password@cluster.mongodb.net/?retryWrites=true&w=majority

DATABASE_NAME=starlance

# ── Seguridad ─────────────────────────────────────────────────
# Genera uno seguro: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=starlance-secret-key-mora-rivera-2026-dev-only

# ── Entorno ───────────────────────────────────────────────────
# development | production
ENVIRONMENT=production
